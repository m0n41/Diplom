# FastAPI settings
HOST=0.0.0.0
PORT=8000
DEBUG=true

# JWT secret (generate a strong random value)
JWT_SECRET_KEY=supersecretkeychangeme
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# PostgreSQL connection (local development)
POSTGRES_DSN=postgresql+psycopg2://postgres:2020@localhost:5432/authdb

# Bcrypt work factor
BCRYPT_ROUNDS=12

# Logging
LOG_LEVEL=INFO